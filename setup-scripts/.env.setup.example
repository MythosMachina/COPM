# COPM unattended setup example
# Copy to a private file (e.g. /root/copm.setup.env) and adjust values.

# Source code path (this repository)
COPM_SOURCE_DIR=/CodexDev/CodexNotesSystem

# Target installation path
COPM_INSTALL_DIR=/opt/copm

# Linux runtime account for services
COPM_RUN_USER=copm
COPM_RUN_GROUP=copm

# systemd service names (without .service suffix)
COPM_SYSTEMD_WEB_SERVICE=codex-notes-system
COPM_SYSTEMD_AGENT_SERVICE=codex-notes-agent

# Web runtime
COPM_WEB_PORT=3300
COPM_WEB_HOST=0.0.0.0
COPM_BASE_URL=http://127.0.0.1:3300
NEXTAUTH_URL=http://127.0.0.1:3300
NEXTAUTH_SECRET=replace-with-64-char-random

# Database (required)
DATABASE_URL=postgresql://copm:change_me@127.0.0.1:5432/codex_ops?schema=public

# Agent runtime (required)
COPM_AGENT_API_TOKEN=replace-with-copm-agent-token
COPM_AGENT_WORKSPACE_ROOT=/var/lib/copm/workspaces
COPM_AGENT_POLL_INTERVAL_MS=10000
COPM_AGENT_STALE_RUN_MINUTES=2
COPM_AGENT_MAX_RUN_MS=300000
COPM_AGENT_CODEX_COMMAND=codex
# IMPORTANT: Codex CLI must be installed and authenticated in root context
# because the agent service runs as root for consistent execution behavior.
# Keep empty for defaults used by worker; otherwise set full args string.
COPM_AGENT_CODEX_ARGS=

# Optional adapters / integrations
DOMNEX_BASE_URL=
DOMNEX_API_TOKEN=
GITHUB_API_TOKEN=
GITHUB_USERNAME=
GITHUB_EMAIL=
